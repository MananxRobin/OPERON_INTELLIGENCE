# ── Frontend Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# VITE_ prefix is required — Vite only exposes variables with this prefix to the browser.

# DeepSeek API key — used to refresh the synthetic complaint pool every 10 minutes.
# Get your key at: https://platform.deepseek.com
# If omitted, the pool stays static (seeded at startup with 600 synthetic complaints).
VITE_DEEPSEEK_API_KEY=
