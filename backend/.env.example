# ── Backend Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Preferred OpenAI API key for the LLM-assisted complaint analysis path.
# When configured, OpenAI is used ahead of DeepSeek.
OPENAI_API_KEY=

# Optional OpenAI model. Fast default for the current backend integration.
OPENAI_MODEL=gpt-5.4-mini

# Optional DeepSeek API key for fallback or legacy setups.
# If both OpenAI and DeepSeek keys are present, OpenAI takes priority.
DEEPSEEK_API_KEY=

# Optional DeepSeek model for the legacy path.
DEEPSEEK_MODEL=deepseek-chat

# Optional SQLite path override. Defaults to backend/complaints.db
OPERON_DB_PATH=

# Optional SQLite path override for the CFPB cache database.
# Defaults to backend/cfpb_cache.db
OPERON_CFPB_DB_PATH=

# Optional comma-separated CORS origins for deployed frontends.
OPERON_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Set to 1 to disable the recurring scheduler loop.
OPERON_DISABLE_SCHEDULER=0

# Set to 0 to disable the default startup CFPB bootstrap ingest.
# By default the app now attempts an initial live CFPB pull so the dataset is
# larger than the small seeded sample set on first boot.
OPERON_ENABLE_STARTUP_INGEST=1

# Set to 1 only when you want FastAPI to serve frontend/dist for non-API routes.
# Keep this off in normal development where Vite runs separately on port 5173.
OPERON_SERVE_FRONTEND=0
