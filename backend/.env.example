# ── Backend Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.

# DeepSeek API key — powers the 5-agent AI pipeline:
#   Classification → Compliance Risk → Routing → Resolution → QA Validation
# Get your key at: https://platform.deepseek.com
# Without this, /api/complaints/analyze returns HTTP 500.
# All CFPB data views (Dashboard, LiveFeed, Analysis, etc.) still work without it.
DEEPSEEK_API_KEY=

# Optional: choose the DeepSeek model for the agent pipeline.
# Recommended for demo speed: deepseek-chat
DEEPSEEK_MODEL=deepseek-chat

# Optional SQLite path override. Defaults to backend/complaints.db
OPERON_DB_PATH=

# Optional comma-separated CORS origins for deployed frontends.
OPERON_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Set to 1 to disable the recurring scheduler loop.
OPERON_DISABLE_SCHEDULER=0

# Set to 1 only if you want a startup CFPB ingest immediately after boot.
# Default behavior is safe startup without eager ingestion.
OPERON_ENABLE_STARTUP_INGEST=0
