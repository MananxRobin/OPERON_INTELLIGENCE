# ── Backend Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.

# OpenAI API key — required for the 5-agent AI pipeline (Classification →
# Compliance Risk → Routing → Resolution → QA Validation).
# Get your key at: https://platform.openai.com/api-keys
# Without this key, /api/complaints/analyze returns HTTP 500.
# All CFPB data views (Dashboard, LiveFeed, Analysis, etc.) still work without it.
OPENAI_API_KEY=
